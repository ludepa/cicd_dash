{
  "datasets": [
    {
      "name": "225e5937",
      "displayName": "v_core_financials",
      "config": {
        "version": "1.1",
        "source": "classic_stable_af2etd_catalog.finserv_gold.v_core_financials",
        "dimensions": [
          {
            "expr": "source.*"
          }
        ],
        "measures": [
          {
            "name": "count",
            "expr": "COUNT(*)",
            "comment": "Represents the total number of rows in the dataset. Use this measure to count all",
            "displayName": "Count"
          }
        ]
      }
    }
  ],
  "pages": [
    {
      "name": "79da53ae",
      "displayName": "Core",
      "layout": [
        {
          "widget": {
            "name": "header",
            "multilineTextboxSpec": {
              "lines": [
