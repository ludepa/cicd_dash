        },
        {
          "widget": {
            "name": "revenue_by_sector",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "225e5937",
                  "fields": [
                    {
                      "name": "gics_sector",
                      "expression": "`gics_sector`"
                    },
                    {
                      "name": "sum(revenue)",
                      "expression": "SUM(`revenue`)"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "frame": {
                "title": "Revenue by GICS Sector",
                "showTitle": true
              },
              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "gics_sector",
                  "axis": {
                    "labelAngle": 45
                  },
                  "scale": {
                    "type": "categorical"
                  }
                },
                "y": {
                  "fieldName": "sum(revenue)",
                  "format": {
                    "type": "number-currency",
                    "currencyCode": "USD",
                    "abbreviation": "compact"
                  },
                  "scale": {
                    "type": "quantitative"
                  }
                }
              },
              "data": {
                "queryName": "main_query"
              }
            }
          },
          "position": {
